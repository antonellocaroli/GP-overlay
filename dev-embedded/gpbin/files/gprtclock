user="root:root"

depend() {
    use alsasound
    after bootmisc
}

_rtclock() {
echo 3072 >/sys/class/rtc/rtc0/max_user_freq
echo 3072 >/proc/sys/dev/hpet/max-user-freq
rc-service "${SVCNAME}" stop
}

start() {
	ebegin "Starting ${SVCNAME}"
        _rtclock
        eend $?
}
