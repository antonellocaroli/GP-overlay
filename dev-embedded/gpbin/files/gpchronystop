user="root:root"

depend() {
    use alsasound
    after local gpireteonline
}

_chronystop() {
sleep 40
rc-service chronyd stop
rc-service "${SVCNAME}" stop
}

start() {
	ebegin "Starting ${SVCNAME}"
        _chronystop
        eend $?
}
